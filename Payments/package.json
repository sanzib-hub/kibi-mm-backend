{
  "name": "kibi-payments-service",
  "version": "1.0.0",
  "description": "KIBI Payments Microservice - Handles payment and payout registrations",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "build:prod": "tsc --project tsconfig.prod.json",
    "start": "node dist/server.js",
    "start:prod": "node dist/server.js",
    "test": "jest --passWithNoTests --detectOpenHandles",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "rebuild": "rm -rf dist && tsc"
  },
  "keywords": [
    "kibi",
    "events",
    "sports",
    "athletes",
    "registration",
    "microservice"
  ],
  "author": "KIBI Sports",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/storage": "^7.18.0",
    "axios": "^1.12.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "helmet": "^7.1.0",
    "firebase-admin": "^13.5.0",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "kysely": "^0.27.3",
    "nodemailer": "^6.9.13",
    "pg": "^8.11.3",
    "razorpay": "^2.9.6",
    "redis": "^5.8.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/google-cloud__storage": "^2.3.1",
    "@types/jest": "^30.0.0",
    "@types/joi": "^17.2.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.11.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.8",
    "jest": "^30.2.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
